{
  "name": "github_workflows",
  "version": "1.0.0",
  "description": "Full-stack project with OpenAPI contract",
  "main": "index.js",
  "scripts": {
    "openapi:validate": "redocly lint openapi/openapi.yml --config .redocly.yaml",
    "openapi:bundle": "redocly bundle openapi/openapi.yml -o openapi/openapi.json",
    "openapi:generate-zod": "node scripts/generate-zod.js",
    "openapi:generate-zod-client": "openapi-zod-client openapi/openapi.yml -o frontend/src/app/schemas/generated/api-client.ts --export-schemas",
    "openapi:docs": "node scripts/serve-docs.js"
  },
  "keywords": [
    "openapi",
    "contract",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@redocly/cli": "^2.24.0",
    "express": "^5.2.1",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  }
}